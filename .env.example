# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1

# Database (SQLite)
DATABASE_URL=sqlite:////home/user/local-music-player/data/music.db

# File paths
DOWNLOADS_PATH=/home/user/local-music-player/downloads
DATA_PATH=/home/user/local-music-player/data
PLAYLISTS_PATH=/home/user/local-music-player/playlists

# Syncthing (optional — leave blank to disable)
SYNCTHING_URL=http://localhost:8384
SYNCTHING_API_KEY=

# CORS (comma-separated origins, * for all)
ALLOWED_ORIGINS=*

# Optional: set a Bearer token to protect the UI
SECRET_TOKEN=

# YouTube OAuth2 (Google Cloud Console)
# Create OAuth2 credentials at https://console.cloud.google.com/
# Application type: Web application
# Authorized redirect URI: http://localhost:8000/api/v1/youtube/auth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/youtube/auth/callback
